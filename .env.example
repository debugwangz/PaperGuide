# PaperGuide Configuration

# LLM Provider: openai or claude
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Claude settings (if using claude)
# ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=

# Set to false if your model doesn't support images
SUPPORT_IMAGES=true

# Search provider
SEARCH_PROVIDER=brave
BRAVE_API_KEY=BSA-xxx

# Output directory
OUTPUT_DIR=outputs
